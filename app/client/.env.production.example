# ==============================================================================
# FundChain Frontend - Production Environment Variables
# ==============================================================================
# Copy this file to .env.local (never commit the real .env.local).
# Only these two VITE_ variables belong in the frontend.
# All secrets (service role key, AI keys, wallet private keys) MUST stay
# in Supabase Edge Function secrets — never here.
# ==============================================================================

# Required: Your Supabase project URL (safe to expose — enforced by RLS)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Required: Supabase anon/public key (safe to expose — enforced by RLS)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ==============================================================================
# SECRETS THAT MUST NEVER APPEAR HERE (set in Supabase Edge Function secrets):
# - SUPABASE_SERVICE_ROLE_KEY
# - OPENROUTER_API_KEY
# - AI_SERVICE_SECRET
# - AI_SERVICE_URL
# - JWT_SECRET
# - TREASURY_PRIVATE_KEY_JSON
# - TREASURY_PRIVATE_KEY_BASE58
# ==============================================================================
